<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" prefWidth="350.0" prefHeight="300.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.damdi.francisco.controllers.GestionEmpleadoController" stylesheets="@style.css">
    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/></padding>

    <Label text="Alta de Nuevo Empleado" styleClass="label-titulo"/>

    <TextField fx:id="txtNuevoUsuario" promptText="Nombre de usuario nuevo"/>
    <PasswordField fx:id="txtNuevaPassword" promptText="Contraseña del empleado"/>

    <Button text="Registrar Empleado" onAction="#registrarEmpleado" styleClass="button-primario"/>

    <Label fx:id="lblMensaje"/>
</VBox>
