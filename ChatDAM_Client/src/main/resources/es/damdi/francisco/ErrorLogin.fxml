<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" prefWidth="300.0" prefHeight="150.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.damdi.francisco.controllers.ErrorLoginController" stylesheets="@style.css">
    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>

    <Label text="Error de Autenticación" styleClass="label-titulo"/>
    <Label text="Usuario o contraseña incorrectos."/>

    <Button text="Salir de la aplicación" onAction="#salir" styleClass="button-danger"/>
</VBox>